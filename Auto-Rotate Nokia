#include <SPI.h>
#include <Adafruit_GFX.h>
#include <Adafruit_PCD8544.h>
#include <Wire.h>

// ============================================
// Nokia 5510 LCD Pin Connections (your setup)
// ============================================
#define SCLK_PIN D1  // Serial Clock
#define DIN_PIN  D2  // Data In (MOSI)
#define DC_PIN   D5  // Data/Command
#define CS_PIN   D6  // Chip Select (SCE)
#define RST_PIN  D7  // Reset

// ============================================
// MPU6050 is on D3 (SDA) and D4 (SCL)
// ============================================

// Create display object
Adafruit_PCD8544 display = Adafruit_PCD8544(SCLK_PIN, DIN_PIN, DC_PIN, CS_PIN, RST_PIN);

// MPU6050 variables
int currentRotation = 0;  // 0=Normal, 1=Right, 2=Upside Down, 3=Left
float accX, accY, accZ;
float angle;

// Timing
unsigned long lastUpdate = 0;
const unsigned long updateInterval = 150;

void setup() {
  Serial.begin(115200);
  delay(1000);
  
  Serial.println("=== Auto-Rotate Hello World ===");
  Serial.println("MPU6050 on D3/D4");
  Serial.println("Nokia LCD on D1/D2/D5/D6/D7");
  
  // ==========================================
  // Initialize MPU6050 (I2C on D3/D4)
  // ==========================================
  Wire.begin(D3, D4);  // SDA=D3, SCL=D4
  Wire.setClock(100000);
  
  // Check if MPU is responding
  Wire.beginTransmission(0x68);
  if(Wire.endTransmission() != 0) {
    Serial.println("❌ MPU6050 not found!");
    while(1) {
      delay(1000);
      Serial.println("Check wiring: SDA→D3, SCL→D4, VCC→3.3V, GND→GND");
    }
  }
  Serial.println("✅ MPU6050 found!");
  
  // Configure MPU6050
  Wire.beginTransmission(0x68);
  Wire.write(0x6B);  // Power management register
  Wire.write(0x00);  // Wake up
  Wire.endTransmission();
  
  delay(100);
  
  // Calibrate gyro (keep sensor still!)
  Serial.println("Calibrating MPU6050... Keep sensor still!");
  calibrateMPU();
  Serial.println("Calibration complete!");
  
  // ==========================================
  // Initialize Nokia LCD
  // ==========================================
  display.begin();
  display.setContrast(60);  // Adjust for best visibility
  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(BLACK);
  
  // Show initial display
  updateDisplay();
  Serial.println("Ready!");
  Serial.println("Rotate the board to see auto-rotation!");
}

void loop() {
  // Update MPU data
  readMPU();
  
  // Calculate angle from accelerometer
  angle = atan2(accY, accX) * 180 / PI;
  
  // Determine rotation
  int newRotation = currentRotation;
  if(angle > -45 && angle < 45) {
    newRotation = 0;  // Normal
  } else if(angle >= 45 && angle < 135) {
    newRotation = 1;  // Rotate Right (90°)
  } else if(angle >= 135 || angle <= -135) {
    newRotation = 2;  // Upside Down (180°)
  } else if(angle < -45 && angle > -135) {
    newRotation = 3;  // Rotate Left (270°)
  }
  
  // If orientation changed, update display
  if(newRotation != currentRotation) {
    currentRotation = newRotation;
    display.setRotation(currentRotation);
    updateDisplay();
    
    // Debug output
    Serial.print("Angle: ");
    Serial.print(angle);
    Serial.print("° | Rotation: ");
    Serial.println(currentRotation);
  }
  
  delay(50);
}

// ==========================================
// MPU6050 Functions (I2C on D3/D4)
// ==========================================

void readMPU() {
  Wire.beginTransmission(0x68);
  Wire.write(0x3B);  // Start at ACCEL_XOUT_H
  Wire.endTransmission();
  
  Wire.requestFrom(0x68, 6);  // Request 6 bytes (X, Y, Z)
  
  if(Wire.available() >= 6) {
    int16_t accelX = (Wire.read() << 8) | Wire.read();
    int16_t accelY = (Wire.read() << 8) | Wire.read();
    int16_t accelZ = (Wire.read() << 8) | Wire.read();
    
    // Convert to G's (16384 LSB/G at ±2G)
    accX = accelX / 16384.0;
    accY = accelY / 16384.0;
    accZ = accelZ / 16384.0;
  }
}

void calibrateMPU() {
  float sumX = 0, sumY = 0, sumZ = 0;
  int samples = 100;
  
  for(int i = 0; i < samples; i++) {
    readMPU();
    sumX += accX;
    sumY += accY;
    sumZ += accZ;
    delay(5);
  }
  
