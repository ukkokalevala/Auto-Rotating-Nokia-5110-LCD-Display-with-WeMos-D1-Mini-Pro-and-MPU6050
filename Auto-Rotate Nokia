}

// ==========================================
// Display Functions
// ==========================================

void updateDisplay() {
  display.clearDisplay();
  
  bool isVertical = (currentRotation == 1 || currentRotation == 3);
  
  if(isVertical) {
    // Vertical orientation - display text in 2 lines
    display.drawRect(0, 0, 47, 83, BLACK);
    
    // Line 1: "Hello"
    display.setCursor(5, 25);
    display.println("Hello");
    
    // Line 2: "World!"
    display.setCursor(5, 38);
    display.println("World!");
    
  } else {
    // Horizontal orientation - full 84x48 area
    display.drawRect(0, 0, 83, 47, BLACK);
    display.setCursor(10, 20);
    display.println("Hello World!");
  }
  
  // Show rotation indicator
  display.setCursor(60, 0);
  switch(currentRotation) {
    case 0: display.print("N"); break;
    case 1: display.print("R"); break;
    case 2: display.print("U"); break;
    case 3: display.print("L"); break;
  }
  
  display.display();
}
